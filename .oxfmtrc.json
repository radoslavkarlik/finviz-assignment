{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["packages/frontend/src/api/**/*", "swagger.json", "parsed.json"],
  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "./packages/frontend/src/style.css",
    "functions": ["cn"],
    "preserveWhitespace": true
  }
}
