{
  "openapi": "3.0.0",
  "info": {
    "title": "Taxonomy API",
    "version": "1.0.0",
    "description": "API for browsing and searching taxonomy items"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "summary": "Get paginated taxonomy items",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (1-based)",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of items per page",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Filter items by name (case-insensitive substring match)",
            "schema": { "type": "string" }
          },
          {
            "name": "delay",
            "in": "query",
            "description": "Artificial delay in milliseconds before responding",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of taxonomy items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaxonomyResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaxonomyItem": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "size": { "type": "integer" }
        }
      },
      "TaxonomyResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TaxonomyItem" }
          },
          "total": { "type": "integer" }
        }
      }
    }
  }
}
