{
  "openapi": "3.0.0",
  "info": {
    "title": "My TypeScript API",
    "version": "1.0.0",
    "description": "A local API documented via a static JSON file"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "summary": "Get all taxonomy items",
        "responses": {
          "200": {
            "description": "A list of taxonomy items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TaxonomyItem" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaxonomyItem": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        }
      }
    }
  }
}
