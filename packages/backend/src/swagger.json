{
  "openapi": "3.0.0",
  "info": {
    "title": "Taxonomy API",
    "version": "1.0.0",
    "description": "API for browsing and searching taxonomy items"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/api": {
      "get": {
        "summary": "Get paginated taxonomy items",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (1-based)",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "offset",
            "in": "query",
            "description": "Number of items per page",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Filter items by name (case-insensitive substring match)",
            "schema": { "type": "string" }
          },
          {
            "name": "delay",
            "in": "query",
            "description": "Artificial delay in milliseconds before responding",
            "schema": { "type": "integer", "default": 0 }
          },
          {
            "name": "subfolders",
            "in": "query",
            "description": "Whether to include subfolders in the response",
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "parent",
            "in": "query",
            "description": "Filter items to those whose name starts with this prefix",
            "schema": { "type": "string" }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "Property to sort by",
            "schema": { "type": "string", "enum": ["name", "size", "subPath"], "default": "name" }
          },
          {
            "name": "sortDir",
            "in": "query",
            "description": "Sort direction",
            "schema": { "type": "string", "enum": ["asc", "desc"], "default": "asc" }
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated list of taxonomy items",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaxonomyResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaxonomyTreeItemResponse": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "size": { "type": "integer" },
          "fullName": {
            "type": "string",
            "description": "Full taxonomy path joined by ' > '"
          }
        }
      },
      "TaxonomyResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the root/parent node"
          },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TaxonomyTreeItemResponse" }
          },
          "total": {
            "type": "integer",
            "description": "Total number of children under the root/parent node"
          }
        }
      }
    }
  }
}
