{
  "name": "@finviz-assignment/backend",
  "version": "0.0.0",
  "private": true,
  "author": "Radoslav Karlik",
  "imports": {
    "#*.json": "./src/*.json",
    "#*": "./src/*.ts"
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outdir=dist --external:@electric-sql/pglite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ts": "tsc -b --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "parse:taxonomy": "tsx scripts/parse.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.5.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0"
  }
}
